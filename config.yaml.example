# kanban-watcher 配置文件
# 复制到 ~/.config/kanban-watcher/config.yaml 后修改

# vibe-kanban 本地 API 地址（通常无需修改）
kanban_api_url: "http://127.0.0.1:7777"

# MQTT 配置 ─ 连接到外部部署的 broker（域名方式，无 TLS）
mqtt:
  # 格式：tcp://<域名>:1883
  # 示例：tcp://aliyun.huajiejun.cn:1883
  broker: "tcp://aliyun.huajiejun.cn:1883"
  username: "mqtt"                 # MQTT 用户名
  password: "wolale1990"           # MQTT 密码
  client_id: "kanban-watcher"      # 唯一标识，同一网络内不能重复

# 对话日志同步到 Home Assistant
conversation_sync:
  enabled: true
  # 不填则自动按平台使用默认目录：
  # macOS: ~/Library/Application Support/ai.bloop.vibe-kanban
  # Linux: ~/.local/share/vibe-kanban
  # Windows: %APPDATA%/ai.bloop.vibe-kanban
  base_dir: ""
  recent_message_limit: 20
  recent_tool_call_limit: 5

# 企业微信应用通知配置（支持应用API + Webhook降级）
wechat:
  corp_id: "ww1234567890abcdef"      # 企业 ID
  agent_id: "1000001"                # 应用 AgentID
  secret: "YOUR_SECRET"               # 应用 Secret
  to_user: "@all"                    # 接收消息的成员账号（@all 表示全部成员）
  proxy_url: "http://wx.huajiejun.cn" # API 代理地址（建议填写以使用固定出口 IP）
  # webhook_url: ""                  # Webhook降级地址（应用失败时使用，不填则不降级）
  notify_threshold_minutes: 10       # has_unseen_turns 或 has_pending_approval 持续多少分钟后发通知

# 本地弹框通知配置
notify:
  # 超时阈值配置（分钟）
  approval_threshold: 5    # 待审批超时
  message_threshold: 10   # 未读消息超时
  # 叠加提醒间隔（分钟）
  # 弹框确认后，每隔这个时间再次弹框（如果问题还在）
  repeat_interval_minutes: 5
  # 是否启用弹框通知
  enabled: true

# 工作时间（仅在此范围内轮询，跨午夜写法：08:00 到次日 01:00）
working_hours:
  start: "08:00"
  end: "01:00"

# 轮询间隔（秒）
poll_interval_seconds: 15

# Redis 配置（可选，启用后消息缓冲使用 Redis ZSET 提升性能）
# 留空或不配置则使用内存缓冲
redis:
  addr: ""                # Redis 地址，如 "localhost:6379"，为空则不启用
  password: ""            # 密码
  db: 0                   # 数据库编号
  pool_size: 10           # 连接池大小

# 数据持久化配置
database:
  host: "home.huajiejun.cn"
  port: 3306
  user: "kanban_watcher"
  password: "YOUR_DB_PASSWORD"
  database: "kanban_watcher"
  sync_interval_seconds: 30
  batch_size: 100
  message_types:
    - user_message
    - assistant_message
    - tool_use
    - error_message

# Home Assistant 读取的本地 HTTP API
http_api:
  port: 7778
  api_key: "YOUR_API_KEY"
  browser_url_template: ""
