# kanban-watcher 配置文件
# 复制到 ~/.config/kanban-watcher/config.yaml 后修改

# vibe-kanban 本地 API 地址（通常无需修改）
kanban_api_url: "http://127.0.0.1:7777"

# MQTT 配置 ─ 连接到外部部署的 broker（域名方式，无 TLS）
mqtt:
  # 格式：tcp://<域名>:1883
  # 示例：tcp://aliyun.huajiejun.cn:1883
  broker: "tcp://aliyun.huajiejun.cn:1883"
  username: "mqtt"                 # MQTT 用户名
  password: "wolale1990"           # MQTT 密码
  client_id: "kanban-watcher"      # 唯一标识，同一网络内不能重复

# 企业微信应用通知配置
wechat:
  corp_id: "ww1234567890abcdef"      # 企业 ID
  agent_id: "1000001"                # 应用 AgentID
  secret: "YOUR_SECRET"               # 应用 Secret
  to_user: "@all"                    # 接收消息的成员账号（@all 表示全部成员，也可指定 UserID1|UserID2）
  proxy_url: "http://wx.huajiejun.cn" # API 代理地址（不填则直连，建议填写以使用固定出口 IP）
  notify_threshold_minutes: 10       # has_unseen_turns 或 has_pending_approval 持续多少分钟后发通知

# 工作时间（仅在此范围内轮询，跨午夜写法：08:00 到次日 01:00）
working_hours:
  start: "08:00"
  end: "01:00"

# 轮询间隔（秒）
poll_interval_seconds: 15
