# Kanban Watcher 本地开发配置
# 复制此文件为 .env.local 并填入你的实际密钥

# API 配置
VITE_API_KEY=your_api_key_here
VITE_BASE_URL=http://127.0.0.1:7778

# LLM 配置（可选）
VITE_LLM_ENABLED=true
VITE_LLM_BASE_URL=http://localhost:1234
VITE_LLM_MODEL=

# File Browser 配置（可选）
VITE_FILE_BROWSER_URL=http://127.0.0.1:9394
VITE_FILE_BROWSER_REMOTE_URL=https://file.huajiejun.cn
VITE_FILE_BROWSER_ROOT_PREFIX=/Users/huajiejun
