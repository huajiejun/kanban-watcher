{
  "name": "kanban-watcher",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:ha && npm run build:web",
    "build:ha": "vite build --config vite.config.ha.ts",
    "build:web": "vite build --config vite.config.web.ts",
    "test": "vitest run",
    "dev": "vite build --watch --config vite.config.ha.ts",
    "preview": "vite --config vite.config.web.ts"
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "lit": "^3.2.0",
    "marked": "^17.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
